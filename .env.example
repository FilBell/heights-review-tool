PORT=3000

# Okendo API key (already configured for Heights)
OKENDO_API_KEY=fb60e365-8937-400d-90a1-9fc782131d41

# Slack Bot Token — required for Trustpilot reviews from #trustpilot_reviews
# Create a Slack app at https://api.slack.com/apps with scope: channels:history
# Then install to workspace and paste the Bot User OAuth Token here
SLACK_TOKEN=xoxb-your-token-here

# Anthropic API key — required for the "Campaign Match" feature
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Cache TTL in minutes (default: 60)
CACHE_TTL_MINUTES=60
